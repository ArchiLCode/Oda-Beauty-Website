---
import type { LandingContent } from '../content/types';

interface Props {
  content: LandingContent;
}

const { content } = Astro.props;
---

<footer class="footer" id="contacts">
  <div class="container footer-grid">
    <div class="footer-brand-block">
      <a class="footer-brand" href="#main">
        <span class="brand-wordmark">O<span>Da</span></span>
        <small>Beauty Salon</small>
      </a>
      <p>Ваш салон красоты для сияния и уверенности. Премиальный уход, опытные мастера и безупречный результат каждый день.</p>
      <div class="social-row">
        {content.socials.filter((social) => ['vk', 'instagram', 'whatsapp'].includes(social.id)).map((social) => (
          <a class="icon-link" href={social.url} target="_blank" rel="noreferrer" aria-label={social.label}>
            <img src={social.icon.src} alt="" loading="lazy" />
          </a>
        ))}
      </div>
    </div>
    <div class="footer-contacts">
      <h2>Контакты</h2>
      <ul class="contact-list">
        <li><a href={content.contacts.phoneHref}>{content.contacts.phone}</a></li>
        <li>
          <a href={content.contacts.mapUrl} target="_blank" rel="noreferrer">
            {content.contacts.city}, {content.contacts.address}
          </a>
        </li>
        <li>{content.contacts.hours}</li>
      </ul>
      <a class="button button--ghost footer-whatsapp" href={content.socials.find((social) => social.id === 'whatsapp')?.url} target="_blank" rel="noreferrer">
        Написать в WhatsApp
      </a>
    </div>
    <div class="footer-map">
      <h2>Мы на карте</h2>
      <iframe
        class="map-frame"
        src={content.contacts.mapEmbedUrl}
        loading="lazy"
        title="ODa Beauty на карте"
      ></iframe>
      <div class="footer-map-meta">
        <p>{content.contacts.address}, {content.contacts.city}</p>
        <p>{content.contacts.hours}</p>
      </div>
    </div>
  </div>
  <div class="container footer-bottom">
    <span>© 2026 ODa Beauty Salon</span>
    <a href="#main">Политика конфиденциальности</a>
    <span>Сделано с любовью <span aria-hidden="true">♡</span></span>
  </div>
</footer>
