---
import type { LandingContent } from '../content/types';

interface Props {
  content: LandingContent;
}

const { content } = Astro.props;
const defaultCategory = content.services.categories[0].id;
const categoryIcons: Record<string, string> = {
  manicure: '<svg viewBox="0 0 24 24"><path d="M8 21c-1.7-.8-2.7-2.3-2.7-4.2V9.5c0-1.2.9-2.1 2.1-2.1.6 0 1.2.3 1.6.7V4.5c0-1.2.9-2.1 2.1-2.1s2.1.9 2.1 2.1v5.1l2-2.1c.8-.8 2-.8 2.8-.1.8.8.8 2 .1 2.8l-4.5 5.1v5.7"/><path d="M8.9 8.1v5.2"/><path d="M13.1 9.7v3.4"/></svg>',
  pedicure: '<svg viewBox="0 0 24 24"><path d="M8.4 21c-2.1-.9-3.3-2.6-3.3-5.1 0-2.1.7-4.1 2.2-6.2 1-1.4 1.5-2.9 1.5-4.6 0-1.1.8-2 1.9-2 1.4 0 2.2 1.3 2.2 3.5 0 1.4-.2 2.7-.6 3.9h3.4c1.8 0 3.2 1.4 3.2 3.2 0 3.9-3.2 7.3-7.1 7.3H8.4Z"/><path d="M8.6 15.2h8.1"/></svg>',
  brows: '<svg viewBox="0 0 24 24"><path d="M3.5 13.2c3.4-4 7.3-5.3 11.7-3.8 2.5.9 4.3 2.2 5.3 3.8"/><path d="M6.1 14.7c3.3-1.9 6.8-2 10.5-.1"/></svg>',
  lashes: '<svg viewBox="0 0 24 24"><path d="M3.5 12.6c2.2 2.5 5.1 3.8 8.5 3.8s6.3-1.3 8.5-3.8"/><path d="M6 10.2l-2-1.9"/><path d="M9.9 11.4l-.7-2.8"/><path d="M14.1 11.4l.7-2.8"/><path d="M18 10.2l2-1.9"/></svg>',
  makeup: '<svg viewBox="0 0 24 24"><path d="M5.5 20.5 17.8 8.2c.9-.9.9-2.3 0-3.2l-.8-.8c-.9-.9-2.3-.9-3.2 0L1.5 16.5v4h4Z"/><path d="m12.2 5.8 6 6"/><path d="M14.8 18.5h6.3"/></svg>',
  hair: '<svg viewBox="0 0 24 24"><path d="M8.2 21c-1-2.3-.8-4.4.7-6.3 1.4-1.8 2.1-3.7 2.1-5.8 0-2.7 2.2-4.9 4.9-4.9 2.5 0 4.6 1.8 4.9 4.3"/><path d="M4 20.5c4.8-2.2 7.5-5.7 8.1-10.4"/><path d="M16.4 20.5c-1.7-2.4-2.4-4.9-2-7.6"/></svg>',
  men: '<svg viewBox="0 0 24 24"><path d="M8.3 10.3a4.2 4.2 0 1 1 7.4 0"/><path d="M4.6 14c1.6 4.7 3.9 7 7.4 7s5.8-2.3 7.4-7"/><path d="M6 14.4c4 1.4 8 1.4 12 0"/><path d="M9.5 17.2h5"/></svg>',
};
const previewItems = content.services.categories.flatMap((category) =>
  content.services.items.filter((service) => service.categoryId === category.id).slice(0, 4),
);
---

<section class="section section--compact" id="services">
  <div class="container services-panel" data-services>
    <div class="section-heading center section-heading--panel">
      <h2 class="section-title">Услуги и цены</h2>
    </div>
    <div class="service-tabs" role="tablist" aria-label="Категории услуг">
      {content.services.categories.map((category) => (
        <button
          class="service-tab"
          type="button"
          role="tab"
          data-service-tab={category.id}
          aria-selected={category.id === defaultCategory ? 'true' : 'false'}
        >
          <span class="service-tab-icon" aria-hidden="true" set:html={categoryIcons[category.id]} />
          {category.title}
        </button>
      ))}
    </div>
    <div class="services-grid">
      {previewItems.map((service) => (
        <article
          class:list={['service-row', { 'is-featured': service.featured }]}
          data-service-card={service.categoryId}
          hidden={service.categoryId !== defaultCategory}
        >
          <img src={service.image.src} alt={service.image.alt} loading="lazy" />
          <div>
            <h3>{service.title}</h3>
            <p>{service.price} • {service.duration}</p>
          </div>
          <a class="button button--ghost button--small" href={service.bookingUrl} target="_blank" rel="noreferrer">Записаться</a>
        </article>
      ))}
    </div>
    <a class="button button--ghost services-more" href={content.hero.bookingUrl} target="_blank" rel="noreferrer">
      Смотреть все услуги
    </a>
  </div>
</section>
