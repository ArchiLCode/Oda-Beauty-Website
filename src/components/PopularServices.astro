---
import type { LandingContent } from '../content/types';

interface Props {
  content: LandingContent;
}

const { content } = Astro.props;
const popularTitles = [
  'SMART педикюр (обработка пальчиков и стоп + покрытие)',
  'Наращивание ногтей',
  'Ламинирование бровей',
  'Объём 3D',
];
const popular = popularTitles
  .map((title) => content.services.items.find((service) => service.title === title))
  .filter(Boolean)
  .slice(0, 4);
---

<section class="section section--compact" id="popular">
  <div class="container panel-section">
    <div class="section-heading section-heading--row">
      <h2 class="section-title">Популярные услуги</h2>
      <a class="button button--ghost button--small" href="#services">Смотреть все</a>
    </div>
    <div class="popular-grid">
      {popular.map((service) => service && (
        <article class="card service-card">
          <img src={service.image.src} alt={service.image.alt} loading="lazy" />
          <div class="service-card-body">
            <h3>{service.title}</h3>
            <p>{service.price} • {service.duration}</p>
            <a class="button button--ghost button--small" href={service.bookingUrl} target="_blank" rel="noreferrer">
              Записаться
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
