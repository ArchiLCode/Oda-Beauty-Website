---
import type { LandingContent } from '../content/types';

interface Props {
  content: LandingContent;
}

const { content } = Astro.props;
---

<section class="section section--compact" id="team">
  <div class="container panel-section team-panel">
    <div class="section-heading section-heading--row">
      <h2 class="section-title">Наша команда</h2>
      <a class="button button--ghost button--small" href={content.hero.bookingUrl} target="_blank" rel="noreferrer">Смотреть всех</a>
    </div>
    <div class="media-rail-wrap">
      <button class="rail-button rail-button--floating rail-button--left" type="button" data-rail-prev="team-rail" aria-label="Предыдущие мастера">‹</button>
      <div class="rail" data-rail id="team-rail">
        {content.team.map((member) => (
          <article class="card member-card">
            <img src={member.image.src} alt={member.image.alt} loading="lazy" />
            <div class="info-wrapper">
              <p>{member.role}</p>
              <h3>{member.name}</h3>
              <a class="button button--ghost" href={member.bookingUrl} target="_blank" rel="noreferrer">Записаться к мастеру</a>
            </div>
          </article>
        ))}
      </div>
      <button class="rail-button rail-button--floating rail-button--right" type="button" data-rail-next="team-rail" aria-label="Следующие мастера">›</button>
      <div class="rail-dots" data-rail-dots="team-rail" aria-label="Навигация команды">
        <button type="button" aria-label="Показать мастера 1" aria-current="true"></button>
        <button type="button" aria-label="Показать мастера 2"></button>
        <button type="button" aria-label="Показать мастера 3"></button>
      </div>
    </div>
  </div>
</section>
