---
import type { JobsPageContent } from '../content/types';

interface Props {
  content: JobsPageContent;
}

const { content } = Astro.props;
const odaIndex = content.page.hero.title.indexOf('ODa');
const heroTitlePrefix = odaIndex >= 0 ? content.page.hero.title.slice(0, odaIndex) : content.page.hero.title;
const heroTitleSuffix = odaIndex >= 0 ? content.page.hero.title.slice(odaIndex + 3) : '';

const iconMap: Record<string, string> = {
  heart: '<svg viewBox="0 0 24 24"><path d="M12 20.4S4.5 16.1 4.5 10.9a4.1 4.1 0 0 1 7.5-2.3 4.1 4.1 0 0 1 7.5 2.3c0 5.2-7.5 9.5-7.5 9.5Z"/></svg>',
  education: '<svg viewBox="0 0 24 24"><path d="m3.5 8.5 8.5-4 8.5 4-8.5 4-8.5-4Z"/><path d="M6.5 10.2v5.1c1.7 1.6 3.5 2.4 5.5 2.4s3.8-.8 5.5-2.4v-5.1"/><path d="M20.5 8.5v5.8"/></svg>',
  percent: '<svg viewBox="0 0 24 24"><path d="m6.5 17.5 11-11"/><circle cx="8" cy="8" r="2.2"/><circle cx="16" cy="16" r="2.2"/></svg>',
  star: '<svg viewBox="0 0 24 24"><path d="m12 3.5 2.7 5.4 6 .9-4.3 4.2 1 5.9-5.4-2.8-5.4 2.8 1-5.9-4.3-4.2 6-.9L12 3.5Z"/></svg>',
  gift: '<svg viewBox="0 0 24 24"><path d="M4.5 10h15v10h-15V10Z"/><path d="M3.5 6.5h17V10h-17V6.5Z"/><path d="M12 6.5V20"/><path d="M12 6.5c-2.8.2-4.8-.5-4.8-2 0-1 .8-1.7 1.8-1.7 1.4 0 2.4 1.2 3 3.7Z"/><path d="M12 6.5c2.8.2 4.8-.5 4.8-2 0-1-.8-1.7-1.8-1.7-1.4 0-2.4 1.2-3 3.7Z"/></svg>',
  growth: '<svg viewBox="0 0 24 24"><path d="M4.5 18.5h15"/><path d="M6.5 16.5v-4"/><path d="M12 16.5v-7"/><path d="M17.5 16.5v-10"/><path d="m14.8 6.5 2.7-2.6 2.6 2.6"/></svg>',
};

const icon = (name: string) => iconMap[name] ?? iconMap.star;
---

<section class="jobs-page" id="main">
  <div class="container jobs-hero">
    <div class="jobs-hero-copy">
      <nav class="jobs-breadcrumb" aria-label="Хлебные крошки">
        <a href="/#main">Главная</a>
        <span aria-hidden="true">/</span>
        <span>Вакансии</span>
      </nav>
      <h1 class="jobs-title">
        {odaIndex >= 0 ? (
          <>
            {heroTitlePrefix}<span>ODa</span>{heroTitleSuffix}
          </>
        ) : content.page.hero.title}
      </h1>
      <p class="jobs-lead">{content.page.hero.text}</p>
      <a class="button jobs-hero-button" href={content.page.hero.ctaUrl}>{content.page.hero.ctaLabel}</a>
    </div>
    <div class="jobs-hero-media" aria-hidden="true">
      <img src={content.page.hero.image.src} alt="" fetchpriority="high" />
    </div>
  </div>

  <div class="container jobs-benefits" aria-label="Преимущества работы в ODa">
    {content.page.benefits.map((benefit) => (
      <article class="jobs-benefit">
        <span class="jobs-icon" aria-hidden="true" set:html={icon(benefit.icon)} />
        <div>
          <h2>{benefit.label}</h2>
          <p>{benefit.text}</p>
        </div>
      </article>
    ))}
  </div>

  <section class="section section--compact" id="vacancies">
    <div class="container panel-section jobs-vacancies-panel">
      <div class="section-heading section-heading--row">
        <h2 class="section-title">Актуальные вакансии</h2>
        {content.vacancies.length > 0 && (
          <a class="button button--ghost button--small jobs-all-link" href={content.page.resumeCta.url} target="_blank" rel="noreferrer">
            Отправить резюме
          </a>
        )}
      </div>

      {content.vacancies.length > 0 ? (
        <div class="jobs-grid">
          {content.vacancies.map((vacancy) => (
            <article class="card job-card">
              <img src={vacancy.image.src} alt={vacancy.image.alt} loading="lazy" />
              <div class="job-card-body">
                <div>
                  <h3>{vacancy.title}</h3>
                  <p class="job-salary">{vacancy.salary}</p>
                  <p class="job-experience">{vacancy.experience}</p>
                </div>
                <ul class="job-requirements">
                  {vacancy.requirements.map((requirement) => <li>{requirement}</li>)}
                </ul>
                <a class="button button--ghost button--small" href={vacancy.applicationUrl} target="_blank" rel="noreferrer">
                  {vacancy.buttonLabel}
                </a>
              </div>
            </article>
          ))}
        </div>
      ) : (
        <div class="jobs-empty">
          <h3>Сейчас нет открытых вакансий</h3>
          <p>Вы можете отправить резюме, и мы свяжемся с вами, когда появится подходящая позиция.</p>
          <a class="button" href={content.page.resumeCta.url} target="_blank" rel="noreferrer">
            {content.page.resumeCta.buttonLabel}
          </a>
        </div>
      )}
    </div>
  </section>

  <section class="section section--compact">
    <div class="container jobs-work-panel">
      <h2 class="section-title">Почему у нас хочется работать</h2>
      <div class="jobs-work-grid">
        {content.page.workBenefits.map((benefit) => (
          <article class="jobs-work-benefit">
            <span class="jobs-icon" aria-hidden="true" set:html={icon(benefit.icon)} />
            <h3>{benefit.label}</h3>
            <p>{benefit.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--tight">
    <div class="container jobs-resume-panel">
      <div class="jobs-resume-image" aria-hidden="true">
        <img src={content.page.resumeCta.image.src} alt="" loading="lazy" />
      </div>
      <div class="jobs-resume-copy">
        <h2>{content.page.resumeCta.title}</h2>
        <p>{content.page.resumeCta.text}</p>
        <a class="button" href={content.page.resumeCta.url} target="_blank" rel="noreferrer">
          {content.page.resumeCta.buttonLabel}
        </a>
      </div>
    </div>
  </section>
</section>
