---
import type { LandingContent } from '../content/types';
import SocialMenu from './SocialMenu.astro';

interface Props {
  content: LandingContent;
}

const { content } = Astro.props;
---

<header class="site-header">
  <div class="header-inner">
    <button class="menu-toggle" type="button" data-menu-toggle aria-expanded="false" aria-controls="mobile-menu">
      <span aria-hidden="true"></span>
      <span class="sr-only">Открыть меню</span>
    </button>
    <a class="header-brand" href="#main" aria-label="ODa Beauty Salon">
      <span class="brand-wordmark">O<span>Da</span></span>
      <small>Beauty Salon</small>
    </a>
    <div class="mobile-actions">
      <SocialMenu id="header-mobile" socials={content.socials} placement="mobile" />
      <a class="mobile-phone-link" href={content.contacts.phoneHref} aria-label={`Позвонить ${content.contacts.phone}`}>
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M7.1 4.8 8.9 4c.8-.3 1.7.1 2 .9l.8 2.1c.3.7.1 1.4-.5 1.9l-.9.7a10.6 10.6 0 0 0 4.1 4.1l.7-.9c.5-.6 1.2-.8 1.9-.5l2.1.8c.8.3 1.2 1.2.9 2l-.8 1.8c-.4.8-1.2 1.3-2.1 1.2C10.8 17.5 6.5 13.2 5.9 7c-.1-.9.4-1.8 1.2-2.2Z" />
        </svg>
      </a>
    </div>
    <nav class="desktop-nav" aria-label="Основная навигация">
      {content.nav.map((item) => <a href={item.href}>{item.label}</a>)}
    </nav>
    <div class="header-actions">
      <a class="header-phone" href={content.contacts.phoneHref}>{content.contacts.phone}</a>
      <a class="header-address" href={content.contacts.mapUrl} target="_blank" rel="noreferrer">
        {content.contacts.city},<br />{content.contacts.address}
      </a>
      <SocialMenu id="header" socials={content.socials} />
    </div>
  </div>
</header>

<nav class="mobile-menu glass" id="mobile-menu" data-mobile-menu data-open="false" aria-label="Мобильная навигация">
  <a class="button" href={content.hero.bookingUrl} target="_blank" rel="noreferrer">Записаться онлайн</a>
  {content.nav.map((item) => <a href={item.href} data-menu-link>{item.label}</a>)}
</nav>
