---
import type { LandingContent } from '../content/types';

interface Props {
  content: LandingContent;
}

const { content } = Astro.props;
const visibleSocials = content.socials.filter((social) => ['vk', 'whatsapp', 'instagram', 'map'].includes(social.id));
---

<header class="site-header">
  <div class="header-inner glass">
    <a class="header-brand brand-wordmark" href="#main" aria-label="ODa Beauty Salon">
      O<span>Da</span>
    </a>
    <nav class="desktop-nav" aria-label="Основная навигация">
      {content.nav.map((item) => <a href={item.href}>{item.label}</a>)}
    </nav>
    <div class="header-actions">
      {visibleSocials.slice(0, 4).map((social) => (
        <a class="icon-link" href={social.url} target="_blank" rel="noreferrer" aria-label={social.label}>
          <img src={social.icon.src} alt="" loading="lazy" />
        </a>
      ))}
      <a class="button" href={content.hero.bookingUrl} target="_blank" rel="noreferrer">Записаться</a>
      <button class="menu-toggle" type="button" data-menu-toggle aria-expanded="false" aria-controls="mobile-menu">
        <span aria-hidden="true"></span>
        <span class="sr-only">Открыть меню</span>
      </button>
    </div>
  </div>
</header>

<nav class="mobile-menu glass" id="mobile-menu" data-mobile-menu data-open="false" aria-label="Мобильная навигация">
  {content.nav.map((item) => <a href={item.href} data-menu-link>{item.label}</a>)}
  <a class="button" href={content.hero.bookingUrl} target="_blank" rel="noreferrer">Записаться онлайн</a>
</nav>
