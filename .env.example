CONTENT_SOURCE=static
SANITY_PROJECT_ID=
SANITY_DATASET=production
# Optional Studio overrides. The CLI mirrors the values above when these are empty.
SANITY_STUDIO_PROJECT_ID=
SANITY_STUDIO_DATASET=production
# Required for import and for builds only when the dataset is private.
SANITY_READ_TOKEN=
SANITY_WRITE_TOKEN=

# Timeweb FTP/FTPS deployment. Prefer ftps when the hosting account supports it.
TIMEWEB_FTP_HOST=
TIMEWEB_FTP_PORT=21
TIMEWEB_FTP_USER=
TIMEWEB_FTP_PASSWORD=
TIMEWEB_FTP_PROTOCOL=ftps
TIMEWEB_FTP_REMOTE_PATH=
